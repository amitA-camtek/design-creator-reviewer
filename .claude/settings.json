{
  "permissions": {
    "allow": [
      "Bash(rm FalconAuditService/Worker.cs FalconAuditService/Program.cs FalconAuditService/appsettings.json FalconAuditWebServer/Program.cs FalconAuditWebServer/appsettings.json)",
      "Bash(rm -rf FalconAuditWebServer/Properties/launchSettings.json FalconAuditService/Properties/launchSettings.json)",
      "PowerShell",
      "Write(*.md)",
      "Write(**/*.md)",
